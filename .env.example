DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vcglone?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/vcglone?sslmode=require"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
AUTH_SECRET="replace-with-the-same-value-as-nextauth-secret"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"
NODE_ENV="development"
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Required for phone and desktop browser push notifications. Generate once with `npm run push:keys`.
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:notifications@your-company.com"

# Required only when bootstrapping the first and only Super Admin with `npm run prisma:seed`.
BOOTSTRAP_SUPER_ADMIN_EMAIL="admin@your-company.com"
BOOTSTRAP_SUPER_ADMIN_PASSWORD="replace-with-a-strong-unique-password"
BOOTSTRAP_SUPER_ADMIN_FIRST_NAME="VCGL"
BOOTSTRAP_SUPER_ADMIN_LAST_NAME="Administrator"


