generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  HR_ADMIN
  SUPER_ADMIN
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
}

enum MaritalStatus {
  SINGLE
  MARRIED
  SEPARATED
  DIVORCED
  WIDOWED
  PREFER_NOT_TO_SAY
}

enum AttendanceStatus {
  CHECKED_IN
  CHECKED_OUT
  PRESENT
  LATE
  ABSENT
  ON_LEAVE
  PENDING_REVIEW
  MANUALLY_ADJUSTED
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ConversationType {
  DIRECT
  GROUP
}

enum TaskStatus {
  ASSIGNED
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  CHANGES_REQUESTED
  COMPLETED
  CANCELLED
}

enum TaskStepStatus {
  ASSIGNED
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskResourceType {
  LINK
  FILE
}

model User {
  id                 String           @id @default(cuid())
  employeeId         String?          @unique
  firstName          String
  lastName           String
  email              String           @unique
  passwordHash       String
  phone              String?
  role               Role             @default(EMPLOYEE)
  departmentId       String?
  managerId          String?
  secondaryManagerId String?
  employmentStatus   EmploymentStatus @default(ACTIVE)
  jobTitle           String?
  dateJoined         DateTime?
  dateOfBirth        DateTime?        @db.Date
  gender             Gender?
  maritalStatus      MaritalStatus?
  aboutMe            String?
  expertise          String?
  chatLastSeenAt     DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  department              Department?            @relation("DepartmentEmployees", fields: [departmentId], references: [id], onDelete: SetNull)
  manager                 User?                  @relation("ManagerReports", fields: [managerId], references: [id], onDelete: SetNull)
  reports                 User[]                 @relation("ManagerReports")
  secondaryManager        User?                  @relation("SecondaryManagerReports", fields: [secondaryManagerId], references: [id], onDelete: SetNull)
  secondaryReports        User[]                 @relation("SecondaryManagerReports")
  managedDepartments      Department[]           @relation("DepartmentManager")
  attendanceRecords       AttendanceRecord[]     @relation("AttendanceEmployee")
  adjustedRecords         AttendanceRecord[]     @relation("AttendanceAdjustedBy")
  leaveBalances           LeaveBalance[]
  leaveRequests           LeaveRequest[]         @relation("LeaveEmployee")
  managerApprovals        LeaveRequest[]         @relation("ManagerApprover")
  hrApprovals             LeaveRequest[]         @relation("HrApprover")
  auditLogs               AuditLog[]             @relation("AuditActor")
  workExperiences         WorkExperience[]
  educationDetails        EducationDetail[]
  dependents              Dependent[]
  notifications           Notification[]
  webPushSubscriptions    WebPushSubscription[]
  createdConversations    Conversation[]         @relation("ConversationCreator")
  conversationMemberships ConversationMember[]
  chatMessages            ChatMessage[]          @relation("ChatMessageSender")
  chatReactions           ChatReaction[]
  assignedTasks           Task[]                 @relation("TaskAssignee")
  delegatedTasks          Task[]                 @relation("TaskAssigner")
  taskComments            TaskComment[]
  taskActivities          TaskActivity[]         @relation("TaskActivityActor")
  taskResources           TaskResource[]         @relation("TaskResourceUploader")
  taskReminderDeliveries  TaskReminderDelivery[]
  assignedTaskSteps       TaskStep[]             @relation("TaskStepAssignee")
  delegatedTaskSteps      TaskStep[]             @relation("TaskStepDelegator")
  managedTaskSteps        TaskStep[]             @relation("TaskStepTargetManager")

  @@index([departmentId])
  @@index([managerId])
  @@index([secondaryManagerId])
  @@index([role])
}

model WorkExperience {
  id             String    @id @default(cuid())
  employeeId     String
  companyName    String
  jobTitle       String
  fromDate       DateTime  @db.Date
  toDate         DateTime? @db.Date
  jobDescription String?
  relevant       Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee User @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EducationDetail {
  id             String    @id @default(cuid())
  employeeId     String
  instituteName  String
  degree         String
  specialization String?
  completionDate DateTime? @db.Date
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  employee User @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Dependent {
  id           String    @id @default(cuid())
  employeeId   String
  name         String
  relationship String
  dateOfBirth  DateTime? @db.Date
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee User @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  managerId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  manager           User?      @relation("DepartmentManager", fields: [managerId], references: [id], onDelete: SetNull)
  employees         User[]     @relation("DepartmentEmployees")
  outgoingTaskSteps TaskStep[] @relation("TaskStepSourceDepartment")
  incomingTaskSteps TaskStep[] @relation("TaskStepTargetDepartment")
}

model AttendanceRecord {
  id                String           @id @default(cuid())
  employeeId        String
  date              DateTime         @db.Date
  checkInTime       DateTime?
  checkOutTime      DateTime?
  checkInLatitude   Float?
  checkInLongitude  Float?
  checkInAccuracy   Float?
  checkInPlaceName  String?
  checkOutLatitude  Float?
  checkOutLongitude Float?
  checkOutAccuracy  Float?
  checkOutPlaceName String?
  checkInNote       String?
  checkOutNote      String?
  checkInUserAgent  String?
  checkOutUserAgent String?
  status            AttendanceStatus @default(CHECKED_IN)
  totalMinutes      Int?
  requiresReview    Boolean          @default(false)
  reviewReason      String?
  manuallyAdjusted  Boolean          @default(false)
  adjustedById      String?
  adjustmentReason  String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  employee   User  @relation("AttendanceEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  adjustedBy User? @relation("AttendanceAdjustedBy", fields: [adjustedById], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([date])
  @@index([status])
  @@index([requiresReview])
}

model LeaveType {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?
  annualEntitlementDays Int      @default(0)
  eligibilityMonths     Int      @default(1)
  requiresDocument      Boolean  @default(false)
  requiresApproval      Boolean  @default(true)
  isPaid                Boolean  @default(true)
  active                Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
}

model LeaveBalance {
  id              String   @id @default(cuid())
  employeeId      String
  leaveTypeId     String
  year            Int
  entitlementDays Int
  usedDays        Int      @default(0)
  remainingDays   Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee  User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, leaveTypeId, year])
  @@index([year])
}

model LeaveRequest {
  id                String             @id @default(cuid())
  employeeId        String
  leaveTypeId       String
  startDate         DateTime           @db.Date
  endDate           DateTime           @db.Date
  totalDays         Int
  reason            String
  attachmentUrl     String?
  status            LeaveRequestStatus @default(PENDING)
  managerApproverId String?
  hrApproverId      String?
  approvalComment   String?
  rejectionReason   String?
  approvedAt        DateTime?
  rejectedAt        DateTime?
  cancelledAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  employee        User      @relation("LeaveEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType       LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Restrict)
  managerApprover User?     @relation("ManagerApprover", fields: [managerApproverId], references: [id], onDelete: SetNull)
  hrApprover      User?     @relation("HrApprover", fields: [hrApproverId], references: [id], onDelete: SetNull)

  @@index([employeeId, status])
  @@index([startDate, endDate])
  @@index([status])
}

model WorkPolicy {
  id                 String   @id @default(cuid())
  workStartTime      String   @default("09:00")
  workEndTime        String   @default("17:00")
  gracePeriodMinutes Int      @default(15)
  timezone           String   @default("Africa/Lagos")
  workingDays        String[] @default(["MONDAY", "TUESDAY", "WEDNESDAY", "THURSDAY", "FRIDAY"])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  message   String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique @db.Text
  p256dh    String   @db.Text
  auth      String   @db.Text
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType
  name        String?
  slug        String?          @unique
  directKey   String?          @unique
  createdById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  createdBy User?                @relation("ConversationCreator", fields: [createdById], references: [id], onDelete: SetNull)
  members   ConversationMember[]
  messages  ChatMessage[]

  @@index([updatedAt])
  @@index([createdById])
}

model ConversationMember {
  id             String    @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime  @default(now())
  lastReadAt     DateTime  @default(now())
  typingUntil    DateTime?
  pinnedAt       DateTime?
  muted          Boolean   @default(false)
  archivedAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId, lastReadAt])
}

model ChatMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  replyToId      String?
  body           String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  conversation Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("ChatMessageSender", fields: [senderId], references: [id], onDelete: Restrict)
  replyTo      ChatMessage?     @relation("ChatMessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      ChatMessage[]    @relation("ChatMessageReplies")
  attachments  ChatAttachment[]
  reactions    ChatReaction[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
}

model ChatAttachment {
  id        String   @id @default(cuid())
  messageId String
  fileName  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ChatReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model Task {
  id              String       @id @default(cuid())
  taskCode        String       @unique
  name            String
  description     String       @db.Text
  expectedOutcome String?      @db.Text
  assigneeId      String
  assignedById    String
  priority        TaskPriority @default(MEDIUM)
  status          TaskStatus   @default(ASSIGNED)
  startAt         DateTime?
  dueAt           DateTime
  reminderOffsets Int[]        @default([1440, 120, 0])
  blockedReason   String?      @db.Text
  submissionNote  String?      @db.Text
  reviewComment   String?      @db.Text
  startedAt       DateTime?
  blockedAt       DateTime?
  submittedAt     DateTime?
  approvedAt      DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  assignee           User                   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  assignedBy         User                   @relation("TaskAssigner", fields: [assignedById], references: [id], onDelete: Restrict)
  resources          TaskResource[]
  comments           TaskComment[]
  activities         TaskActivity[]
  reminderDeliveries TaskReminderDelivery[]
  steps              TaskStep[]

  @@index([assigneeId, status])
  @@index([assignedById, status])
  @@index([status, dueAt])
  @@index([dueAt])
}

model TaskStep {
  id                 String         @id @default(cuid())
  taskId             String
  title              String
  description        String?        @db.Text
  position           Int
  required           Boolean        @default(true)
  assigneeId         String
  assignedById       String
  sourceDepartmentId String?
  targetDepartmentId String?
  targetManagerId    String?
  interdepartmental  Boolean        @default(false)
  status             TaskStepStatus @default(ASSIGNED)
  dueAt              DateTime
  startedAt          DateTime?
  blockedAt          DateTime?
  blockedReason      String?        @db.Text
  completedAt        DateTime?
  completionNote     String?        @db.Text
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  task             Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee         User        @relation("TaskStepAssignee", fields: [assigneeId], references: [id], onDelete: Restrict)
  assignedBy       User        @relation("TaskStepDelegator", fields: [assignedById], references: [id], onDelete: Restrict)
  targetManager    User?       @relation("TaskStepTargetManager", fields: [targetManagerId], references: [id], onDelete: SetNull)
  sourceDepartment Department? @relation("TaskStepSourceDepartment", fields: [sourceDepartmentId], references: [id], onDelete: SetNull)
  targetDepartment Department? @relation("TaskStepTargetDepartment", fields: [targetDepartmentId], references: [id], onDelete: SetNull)

  @@index([taskId, position])
  @@index([assigneeId, status, dueAt])
  @@index([targetManagerId, status, dueAt])
  @@index([sourceDepartmentId, createdAt])
  @@index([targetDepartmentId, createdAt])
  @@index([interdepartmental, status, dueAt])
}

model TaskResource {
  id         String           @id @default(cuid())
  taskId     String
  uploaderId String
  type       TaskResourceType
  title      String
  url        String?          @db.Text
  fileName   String?
  mimeType   String?
  size       Int?
  data       Bytes?
  createdAt  DateTime         @default(now())

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation("TaskResourceUploader", fields: [uploaderId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([uploaderId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId, createdAt])
  @@index([authorId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  taskId    String
  actorId   String?
  action    String
  message   String   @db.Text
  metadata  Json?
  createdAt DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation("TaskActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
}

model TaskReminderDelivery {
  id           String   @id @default(cuid())
  taskId       String
  userId       String
  kind         String
  scheduledFor DateTime
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId, kind, scheduledFor])
  @@index([userId, sentAt])
  @@index([taskId])
}
